<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="RestAssured Framework Parallel Test Suite" parallel="classes" thread-count="3" verbose="1">
    
    <!-- Register custom listeners for report tracking and dynamic retry analyzers -->
    <listeners>
        <listener class-name="com.framework.utils.FrameworkListener" />
        <listener class-name="com.framework.utils.AnnotationTransformer" />
    </listeners>

    <test name="RestAssured API Core &amp; Advanced Integration Tests">
        <classes>
            <class name="com.framework.tests.AuthTest" />
            <class name="com.framework.tests.UserCRUDTest" />
            <class name="com.framework.tests.DataDrivenUserTest" />
            <class name="com.framework.tests.advanced.ComplexJsonValidationTest" />
            <class name="com.framework.tests.advanced.FileUploadDownloadTest" />
            <class name="com.framework.tests.advanced.RateLimitAndSlaTest" />
        </classes>
    </test>
</suite>
